function C = sacSuggest(classifiers, d, timeLimit, searchMethod, pll)

% From the Suggest a Classifier Library (SAC), a Matlab Toolbox for cell
% classification in high content screening. http://www.cellclassifier.org/
% Copyright © 2011 Kevin Smith and Peter Horvath, Light Microscopy Centre 
% (LMC), Swiss Federal Institute of Technology Zurich (ETHZ), Switzerland. 
% All rights reserved.
%
% This program is free software; you can redistribute it and/or modify it 
% under the terms of the GNU General Public License version 2 (or higher) 
% as published by the Free Software Foundation. This program is 
% distributed WITHOUT ANY WARRANTY; without even the implied warranty of 
% MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU 
% General Public License for more details.


% TODO: be flexible in determining which method is best! (support an index
%       of different performance measures, for example)
% TODO: pass options to sub-suggestion functions
% TODO: should be pass back the best trained model(s)?
% TODO: make sure the cmd strings are unique - or we might waste a lot of time!
% TODO: support for stacking
% TODO: check if parallel processing toolbox is available
% TODO: generate a report


global SACROOT
global logFID
global logDIR
global displayMessagePriority
global logMessagePriority
displayMessagePriority = 3;
logMessagePriority = 5;

% choose the metrics to judge performance
%metrics = {'ACC', 'F', 'PRE', 'REC', 'RMS', 'MXE', 'BEP', 'AUC'};
%metrics = {'ACC', 'F', 'PRE', 'REC', 'BEP', 'AUC', 'RMS'};
%allmetrics = {'ACC', 'ERR', 'CORRECT', 'INCORRECT', 'CONFUSION', 'AUC', 'BEP',  'F',  'LFT', 'MXE', 'PR', 'PRE', 'REC', 'RMS', 'ROC'};
metrics = {'ACC', 'AUC', 'BEP', 'F', 'LFT', 'RMS'};

% TODO: add a 2nd vector that has each metric weights

% get a FID for the logfile, and create a folder to put it in
logDIR = datestr(now, 'yyyy-mmm-dd-HH.MM.SS./');
logDIR(15) = 'h';  logDIR(18) = 'm'; logDIR(21) = 's';
logDIR = [SACROOT '/logs/' logDIR];
mkdir(logDIR);
logFID = fopen([logDIR 'sacSuggest.log'], 'w');

% set default values, if not specified
if ~exist('timeLimit', 'var'); timeLimit = 60; end
if ~exist('searchMethod', 'var'); searchMethod = 'random'; end

% are we using parallel toolbox (pll==1 yes / pll=0 no)?
isPL = isParallel();
if ~exist('pll','var'); pll=isPL; elseif (pll==1)&&(pll~=isPL); pll=0; end;

% if a single classifier is given, insert it into a 1x1 cell
if ischar(classifiers); classifiers = {classifiers}; end;


[baseline bayesOptimal] = getBayesOptimal(d, metrics, classifiers);

C.E = []; C.cmds = []; C.OPTs = []; C.status = []; C.metrics = []; C.P = [];
C.bestInds = [];
C = orderfields(C);

for c = 1:numel(classifiers)
    clear E taskTime cmd OPTs status jobOverhead;
    sacLog(3,logFID,'\n=========================== searching %s ===========================\n', classifiers{c});
    
    switch searchMethod
        % ----------------- Random Search ----------------------
        case 'random'
            sacLog(3,logFID,' Random search, %ds time limit (parallel=%d)\n', timeLimit, pll);
            if pll
                [E cmds OPTs status] = sacSuggestRandomDistributed(d, classifiers{c}, timeLimit, metrics); 
            else
                [E cmds OPTs status] = sacSuggestRandomSerial(d, classifiers{c}, timeLimit, metrics);
            end
            
        otherwise
            error('Unknown search method');            
    end
    
    C(c).classifier = classifiers{c};
    C(c).cmds = cmds; C(c).OPTs = OPTs; C(c).E = E; C(c).status = status; %#ok<*AGROW>
    
    sacLog(3,logFID,' %d/%d total configurations were successfully evaluated\n', sum(C(c).status), numel(C(c).status));
    sacLog(3,logFID,'  - - - - - - - - - - - - - results for %s - - - - - - - - - - - - -\n', classifiers{c});
    
    [C bayesOptimal] = sacDetermineBestOptions(C, c, metrics, baseline, bayesOptimal);
    
    
    sacLog(3, logFID, '\n');
    for i = 1:numel(C)
        bestInd = C(i).bestInds(1);
        sacLog(3,logFID,'    P:%1.4f   ',  C(i).P(bestInd));
        for m = 1:numel(metrics)
            sacLog(3,logFID,'%s:%1.4f ', metrics{m}, C(i).metrics(bestInd,m));
        end
        sacLog(3, logFID, '[%s]\n', classifiers{i});
    end
    
<<<<<<< .mine
 %   keyboard;
=======
    %keyboard;
    
>>>>>>> .r146
end


keyboard;

sacLog(3,logFID,'\n===> Optimization complete\n');
fclose('all');








function pll = isParallel()

global logFID

pll = license('test', 'distrib_computing_toolbox');

if pll
    sacLog(3,logFID,' Distributed Computing Toolbox check: OK\n');
else
    sacLog(2,logFID,' Warning: Distributed Computing Toolbox license NOT FOUND.\n It is STRONGLY recommended that SAC is run using the Distributed Computing Toolbox.\n');
end





